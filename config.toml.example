# wspr-recorder configuration
# Copy this file to config.toml and edit as needed.
#
# When installed as a systemd service (standalone mode):
#   Config:     /etc/wspr-recorder/config.toml
#   WAV output: /dev/shm/wspr-recorder/<band>/
#   IPC socket: /run/wspr-recorder/control.sock
#
# Coordination with sigmond / wsprdaemon-client:
#   wspr-recorder is a standalone daemon but normally runs under sigmond
#   alongside wsprdaemon-client. In that deployment, wsprdaemon-client's
#   `wd-ka9q-record` generates a per-receiver config on service start from
#   WD_* env vars (see /etc/sigmond/coordination.env and
#   /etc/wspr-recorder/env/<instance>.env) and execs wspr-recorder -c
#   <generated>.toml. This file is only consulted when wspr-recorder is
#   invoked directly (e.g. for development, testing, or a lone recorder
#   without wsprdaemon-client).

[recorder]
# Output directory for WAV files
# Using /dev/shm for in-memory storage (faster, no disk I/O)
output_dir = "/dev/shm/wspr-recorder"

# Sample format — LEGACY KEY, retained for backward compatibility.
# v4 period WAVs are always peak-normalized int16 regardless of this value
# (see wav_writer.write_period: ring buffer is float32; per-period peak
# normalization to full int16 range happens at WAV-write time, and the
# scale factor is recorded in the JSON sidecar). This setting only
# affects the legacy 1-minute WAV path, which is not used in v4.
sample_format = "float32"

# Maximum age of WAV files in minutes before automatic cleanup
# wsprdaemon processes files within ~2 minutes, so 35 minutes is safe
max_file_age_minutes = 35

# Maximum WAV files per band directory
# If wsprdaemon stops processing, oldest files are deleted to make room
# This prevents filling up /dev/shm
max_files_per_band = 35

# Status file name (written to output_dir)
status_file = "status.json"

# IPC socket for wsprdaemon and other tools to query/control
ipc_socket = "/run/wspr-recorder/control.sock"

[timing]
# Timing authority for minute-boundary sync.
#
# Under the RTP-reference labeling invariant
# (hf-timestd/docs/METROLOGY.md §4.5.1), all WAV labels are derived from
# radiod's RTP timestamps plus an optional RTP→UTC offset from hf-timestd.
# The recorder never consults its own system clock for data labeling;
# the wall clock is used at most ONCE at startup to correlate the RTP
# counter with a UTC minute, after which the GPSDO-clocked RTP counter
# carries the alignment.
#
# "auto" (default): RtpSyncStrategy with optional /run/hf-timestd/authority.json
#   reader. When hf-timestd is running and publishing a usable offset,
#   correlation uses the offset (precise, system-clock-independent). When
#   the file is missing or stale (standalone mode — sigmond client running
#   without hf-timestd), correlation falls back to a one-time wall-clock
#   read at startup. Operator is responsible for ensuring radiod's host
#   clock is at least minute-accurate at startup and that radiod refreshes
#   its RTP_TIMESNAP often enough to keep oscillator drift within WSPR
#   tolerance.
#
# "rtp": RtpSyncStrategy without the authority reader. Legacy explicit-RTP
#   behavior — one-time wall-clock correlation at startup, no later offset
#   application.
#
# "fusion": Deprecated alias for "auto", kept for backward compatibility
#   with older configs.
#
# "legacy-clock": Deprecated. Uses the old ClockSyncStrategy /
#   FallbackSyncStrategy hierarchy that consults the system clock for
#   labeling — violates the RTP-reference invariant. Only set this if you
#   have a specific reason to keep the pre-authority-manager behavior.
authority = "auto"

[radiod]
# REQUIRED: the mDNS control/status multicast name of the radiod to
# consume from.  Discover available radiods on the LAN with:
#   wspr-recorder config init      (interactive wizard, picks one)
#   ka9q-python list               (raw discovery)
# Examples: "bee1-status.local", "rx888-status.local".  Leave the
# placeholder unchanged to make the daemon refuse to start until
# the operator runs the configurator.
status = "<configure-via-config-init>"

# Legacy field name accepted during the Phase 3 deprecation window
# (RADIOD-IDENTIFICATION.md §6).  Greenfield installs should use
# `status` above; existing deployments can keep this until they
# re-run the configurator.
# status_address = "bee3-status.local"

# RTP multicast destination is not configured here — radiod advertises
# per-channel multicast groups via its status stream (discovered through
# status_address), and ka9q-python's MultiStream joins them on demand.

# RTP port (all channels share this port, demuxed by SSRC)
port = 5004

[channel_defaults]
# Sample rate in Hz (12000 is standard for WSPR)
sample_rate = 12000

# Demodulation mode
mode = "usb"

# RTP wire encoding from radiod to the recorder.
# "f32"   - IEEE float32, preserves full dynamic range (recommended for WSPR)
# "s16be" - 16-bit big-endian (half the bandwidth but loses precision on
#           weak signals; S16BE→float32 is done by ka9q-python at the
#           callback boundary, so client-side samples are always float32)
encoding = "f32"

# AGC: false for WSPR (we want consistent levels)
agc = false

# Manual gain in dB (when AGC is off)
gain = 0.0

# Audio filter edges in Hz
# WSPR signals are at 1400-1600 Hz in the audio passband
# 1300-1700 Hz gives some margin
low = 1300
high = 1700

# --------------------------------------------------------------------------
# Band configuration (v4 format)
#
# Each [[band]] section defines a frequency and its decode modes.
# Available modes: W2 (WSPR-2), F2 (FST4W-120), F5 (FST4W-300),
#                  F15 (FST4W-900), F30 (FST4W-1800)
#
# W2 and F2 share the same 2-minute window (one WAV serves both decoders).
# Longer FST4W modes require more memory per band (ring buffer is
# float32 to preserve dynamic range; int16 conversion + per-period peak
# normalization happens at WAV-write time).
#
# Ring capacity per band = longest configured period + 120 s headroom.
# The +120 s keeps the W2 cycle that straddles an odd F-cycle boundary
# (e.g. F5 at minute 5, F15 at minute 15) fully in the ring with margin.
#
# Memory per band (float32 @ 12 kHz):
#   W2/F2 only          (ring =  4 min)  ≈ 11 MB
#   + F5   adds 300 s   (ring =  7 min)  ≈ 20 MB
#   + F15  adds 900 s   (ring = 17 min)  ≈ 49 MB
#   + F30  adds 1800 s  (ring = 32 min)  ≈ 92 MB
# --------------------------------------------------------------------------

[[band]]
frequency = "136000"       # 2200m
modes = ["W2", "F2", "F5", "F15", "F30"]

[[band]]
frequency = "474200"       # 630m
modes = ["W2", "F2", "F5", "F15", "F30"]

[[band]]
frequency = "1836600"      # 160m
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "3568600"      # 80m
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "3592600"      # 80m EU
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "5287200"      # 60m
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "5364700"      # 60m EU
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "7038600"      # 40m
modes = ["W2", "F2"]

[[band]]
frequency = "10138700"     # 30m
modes = ["W2", "F2"]

[[band]]
frequency = "13553900"     # 22m
modes = ["W2"]

[[band]]
frequency = "14095600"     # 20m
modes = ["W2", "F2"]

[[band]]
frequency = "18104600"     # 17m
modes = ["W2"]

[[band]]
frequency = "21094600"     # 15m
modes = ["W2"]

[[band]]
frequency = "24924600"     # 12m
modes = ["W2"]

[[band]]
frequency = "28124600"     # 10m
modes = ["W2"]

[[band]]
frequency = "50293000"     # 6m
modes = ["W2"]

# --------------------------------------------------------------------------
# Legacy format (backward compatible, used if no [[band]] sections above)
# All bands default to W2 (WSPR-2) only.
# --------------------------------------------------------------------------
# [frequencies]
# bands = [
#     "136000",      # 2200m
#     "474200",      # 630m
#     "14095600",    # 20m
# ]
