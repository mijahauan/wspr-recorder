# wspr-recorder configuration
# Copy this file to config.toml and edit as needed
#
# When installed as a systemd service:
#   Config:     /etc/wspr-recorder/config.toml
#   WAV output: /dev/shm/wspr-recorder/<band>/
#   IPC socket: /run/wspr-recorder/control.sock

[recorder]
# Output directory for WAV files
# Using /dev/shm for in-memory storage (faster, no disk I/O)
output_dir = "/dev/shm/wspr-recorder"

# Sample format: "int16" (default, compatible with wsprd) or "float32"
sample_format = "int16"

# Maximum age of WAV files in minutes before automatic cleanup
# wsprdaemon processes files within ~2 minutes, so 35 minutes is safe
max_file_age_minutes = 35

# Maximum WAV files per band directory
# If wsprdaemon stops processing, oldest files are deleted to make room
# This prevents filling up /dev/shm
max_files_per_band = 35

# Status file name (written to output_dir)
status_file = "status.json"

# IPC socket for wsprdaemon and other tools to query/control
ipc_socket = "/run/wspr-recorder/control.sock"

[timing]
# Timing authority for minute-boundary sync.
#
# "auto" (default): Auto-detect the best available timing source, probing
#   downward through the hierarchy:
#     L4 - chrony tracking GPS/PPS with sub-ms dispersion (GPS+PPS on LAN)
#     L3 - hf-timestd Fusion feeding chrony (UTC(NIST), sub-ms)
#     L2 - chrony with WAN NTP pools (~10-100ms)
#     L1 - undisciplined system clock (fallback)
#
# "rtp": Declare that radiod has GPSDO/PPS (L5/L6). The recorder will use
#   RTP timestamps from the stream as the authoritative time source — the
#   wall clock is consulted only once at startup to correlate the RTP
#   timestamp with a UTC minute. All subsequent minute boundaries are
#   derived from the GPSDO-clocked RTP sample counter, independent of the
#   wspr-recorder machine's own clock discipline.
#
#   Set this ONLY if you know radiod is receiving GPS+PPS directly on its
#   host or has HF-injected PPS — it cannot be auto-detected.
#
# "fusion": Force use of hf-timestd Fusion metrology (L3) regardless of
#   other sources. Useful for testing.
authority = "auto"

[radiod]
# radiod status/control multicast address (mDNS name like xxx-status.local)
# Example: bee1-hf-status.local, rx888-status.local
status_address = "bee1-hf-status.local"

# RTP multicast destination for all channels
# Must be in 239.x.x.x range (multicast)
destination = "239.1.2.3"

# RTP port (all channels share this port, demuxed by SSRC)
port = 5004

[channel_defaults]
# Sample rate in Hz (12000 is standard for WSPR)
sample_rate = 12000

# Demodulation mode
mode = "usb"

# Internal encoding (radiod uses float internally)
encoding = "float"

# AGC: false for WSPR (we want consistent levels)
agc = false

# Manual gain in dB (when AGC is off)
gain = 0.0

# Audio filter edges in Hz
# WSPR signals are at 1400-1600 Hz in the audio passband
# 1300-1700 Hz gives some margin
low = 1300
high = 1700

# --------------------------------------------------------------------------
# Band configuration (v4 format)
#
# Each [[band]] section defines a frequency and its decode modes.
# Available modes: W2 (WSPR-2), F2 (FST4W-120), F5 (FST4W-300),
#                  F15 (FST4W-900), F30 (FST4W-1800)
#
# W2 and F2 share the same 2-minute window (one WAV serves both decoders).
# Longer FST4W modes require more memory per band (up to ~43 MB for F30).
#
# Memory per band: W2/F2 only = ~274 KB, F5 = ~720 KB,
#                  F15 = ~2.2 MB, F30 = ~43 MB
# --------------------------------------------------------------------------

[[band]]
frequency = "136000"       # 2200m
modes = ["W2", "F2", "F5", "F15", "F30"]

[[band]]
frequency = "474200"       # 630m
modes = ["W2", "F2", "F5", "F15", "F30"]

[[band]]
frequency = "1836600"      # 160m
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "3568600"      # 80m
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "3592600"      # 80m EU
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "5287200"      # 60m
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "5364700"      # 60m EU
modes = ["W2", "F2", "F5"]

[[band]]
frequency = "7038600"      # 40m
modes = ["W2", "F2"]

[[band]]
frequency = "10138700"     # 30m
modes = ["W2", "F2"]

[[band]]
frequency = "13553900"     # 22m
modes = ["W2"]

[[band]]
frequency = "14095600"     # 20m
modes = ["W2", "F2"]

[[band]]
frequency = "18104600"     # 17m
modes = ["W2"]

[[band]]
frequency = "21094600"     # 15m
modes = ["W2"]

[[band]]
frequency = "24924600"     # 12m
modes = ["W2"]

[[band]]
frequency = "28124600"     # 10m
modes = ["W2"]

[[band]]
frequency = "50293000"     # 6m
modes = ["W2"]

# --------------------------------------------------------------------------
# Legacy format (backward compatible, used if no [[band]] sections above)
# All bands default to W2 (WSPR-2) only.
# --------------------------------------------------------------------------
# [frequencies]
# bands = [
#     "136000",      # 2200m
#     "474200",      # 630m
#     "14095600",    # 20m
# ]
